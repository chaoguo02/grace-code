# ===========================================================================
# Forge Agent 环境变量配置
# ===========================================================================
# 复制此文件为 .env 并填入你的实际值：
#   cp .env.template .env
#
# .env 已在 .gitignore 中，不会被提交到远程仓库。
# 启动时通过 python-dotenv 自动加载，无需手动 export。
# ===========================================================================

# ---------------------------------------------------------------------------
# LLM 核心配置（必填）
# ---------------------------------------------------------------------------

# Provider: deepseek / openai / anthropic / groq / ollama / openai-compat
FORGE_LLM_PROVIDER=deepseek

# Model 名称
FORGE_LLM_MODEL=deepseek-v4-flash

# API Base URL（小米内部 DeepSeek 代理）
FORGE_LLM_BASE_URL=xxxx

# API Key（通过内部平台获取）
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ---------------------------------------------------------------------------
# 备用 Provider（按需启用，取消注释并填入 key）
# ---------------------------------------------------------------------------

# OpenAI
# FORGE_LLM_PROVIDER=openai
# FORGE_LLM_MODEL=gpt-4o
# FORGE_LLM_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-xxxx

# Anthropic (Claude)
# FORGE_LLM_PROVIDER=anthropic
# FORGE_LLM_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=sk-ant-xxxx

# Groq（免费高速推理）
# GROQ_API_KEY=gsk_xxxx

# ---------------------------------------------------------------------------
# 模型下载镜像（中国网络必填）
# ---------------------------------------------------------------------------

# HuggingFace 镜像，用于首次下载 embedding 模型（RAG 外部记忆）
HF_ENDPOINT=https://hf-mirror.com

# ---------------------------------------------------------------------------
# Langfuse Observability
# ---------------------------------------------------------------------------

LANGFUSE_PUBLIC_KEY=pk-lf-xxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxx
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENVIRONMENT=development
FORGE_PROMPT_SOURCE=local
LANGFUSE_PROMPT_LABEL=production
LANGFUSE_PROMPT_VERSION=
LANGFUSE_PROMPT_NAMESPACE=forge
