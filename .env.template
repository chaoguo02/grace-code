# ===========================================================================
# Forge Agent 环境变量配置
# ===========================================================================
# 复制此文件为 .env 并填入你的实际值：
#   cp .env.template .env
#
# .env 已在 .gitignore 中，不会被提交到远程仓库。
# ===========================================================================

# ---------------------------------------------------------------------------
# LLM 配置（必填，至少填一组）
# ---------------------------------------------------------------------------

# 当前使用的 API Base URL（小米内部 DeepSeek 代理）
FORGE_LLM_BASE_URL=https://api.llm.mioffice.cn/v1/

# DeepSeek API Key（通过小米内部平台获取）
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ---------------------------------------------------------------------------
# 备用 Provider（按需启用）
# ---------------------------------------------------------------------------

# OpenAI
# OPENAI_API_KEY=sk-xxxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-xxxx

# Groq（免费高速推理）
# GROQ_API_KEY=gsk_xxxx

# ---------------------------------------------------------------------------
# 模型下载镜像（中国网络必填）
# ---------------------------------------------------------------------------

# HuggingFace 镜像，用于首次下载 embedding 模型
HF_ENDPOINT=https://hf-mirror.com
